# Dependencies & build output — installed/built fresh inside the image
node_modules
dist
build
coverage

# Env files — never bake secrets into the image; Cloud Run env vars only
.env
.env.*
!.env.example

# VCS / editor / OS
.git
.github
.gitignore
.idea
.vscode
.DS_Store

# Docs & misc project files not needed at runtime
# NOTE: tsconfig.json / tsconfig.build.json / nest-cli.json are NOT
# ignored — `nest build` in the build stage needs them.
README.md
DEPLOYMENT.md
*.md
render.yaml
.eslintrc.js
.prettierrc
jest.config.js

# Logs / temp
*.log
npm-debug.log*
.tmp
