# =====================================================================
#  portfolio-backend (NestJS)  —  .env.example
#  Copy this file to ".env" and fill in your real values.
#  (.env is git-ignored; .env.example is the shared key reference.)
# =====================================================================

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated origins allowed to call the API (your frontend)
CORS_ORIGINS=http://localhost:3000

# ── Database — LOCAL PostgreSQL (you manage via DBeaver) ────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Create a DB named "portfolio" in DBeaver, then put YOUR user/password below.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/portfolio?schema=public

# ── Auth (JWT — single admin = you) ─────────────────────────────────
# Use long random strings (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ── Admin seed (your one login; created by the seed script) ─────────
ADMIN_EMAIL=rohitbmalviya@gmail.com
ADMIN_PASSWORD=ChangeMe123!        # change this after first login
ADMIN_NAME=Rohit Malviya

# ── Cloudinary (free account — used for image uploads, incl. local) ─
# Get these from your Cloudinary dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=portfolio

# ── Gmail API — two-way contact message sync ─────────────────────────
GMAIL_USER=your_gmail_address@gmail.com
GOOGLE_CLIENT_ID=your_oauth2_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth2_client_secret
GOOGLE_REFRESH_TOKEN=your_oauth2_refresh_token

# How often to poll Gmail for new messages (standard 5-field cron expression).
# Defaults to every 2 minutes when not set.  Set a longer interval in production
# to stay within Gmail API quotas (e.g. "*/10 * * * *" for every 10 minutes).
# GMAIL_SYNC_CRON=*/2 * * * *

# ── Email template URLs ───────────────────────────────────────────────
SITE_URL=https://rohitmalviya.dev

# Deep-link to the admin messages page — shown as a button in the
ADMIN_MESSAGES_URL=http://localhost:3000/admin/messages
