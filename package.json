    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
