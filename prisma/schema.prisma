// =============================================================
//  portfolio-backend — Prisma Schema
//  DB: PostgreSQL  |  ORM: Prisma 5  |  IDs: cuid()
//
//  Structure source-of-truth: step4.md §3
//  Content seed source-of-truth: step3.md
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────

enum SectionType {
  HERO
  ABOUT
  SKILLS
  EXPERIENCE
  FEATURED_PROJECTS
  PROJECTS_GRID
  BLOG_TEASER
  ACHIEVEMENTS
  EDUCATION
  CONTACT
  METRICS
  RICH_TEXT
  CTA
  GALLERY
}

enum SkillLevel {
  EXPERT
  PROFICIENT
  FAMILIAR
}

enum DefaultTheme {
  DARK
  LIGHT
}

// ─────────────────────────────────────────────────────────────
//  PAGE  —  a URL-addressable page composed of ordered Sections
// ─────────────────────────────────────────────────────────────

model Page {
  id              String    @id @default(cuid())
  slug            String    @unique
  /// Title must also be unique across pages. Migration required after this change:
  ///   npx prisma migrate dev --name add_page_title_unique
  title           String    @unique
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  navLabel        String?
  navOrder        Int       @default(0)
  showInNav       Boolean   @default(false)
  published       Boolean   @default(true)
  /// isSystem = true means this page is required by the app (cannot be deleted from admin)
  isSystem        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sections Section[]

  @@index([slug])
  @@index([showInNav, navOrder])
}

// ─────────────────────────────────────────────────────────────
//  SECTION  —  a predefined-type content block on a Page
//  data(Json) holds the per-type shape (see step4 §3.2)
// ─────────────────────────────────────────────────────────────

model Section {
  id        String      @id @default(cuid())
  pageId    String
  type      SectionType
  /// 0-based display order within the page
  order     Int         @default(0)
  enabled   Boolean     @default(true)
  /// Flexible JSON payload — shape is determined by `type` (see step4 §3.2).
  /// Typed in the shared-types package; stored as opaque JSON here.
  data      Json        @default("{}")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
  @@index([pageId, enabled])
}

// ─────────────────────────────────────────────────────────────
//  PROJECT
// ─────────────────────────────────────────────────────────────

model Project {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  oneLiner        String
  role            String
  tags            String[]
  stack           String[]
  /// Headline metric string displayed on the card (e.g. "148 Prisma models · ~185-endpoint backend")
  metric          String
  liveUrl         String?
  /// Stored as JSON array of { url: string, alt: string }
  screenshots     Json      @default("[]")
  /// Short overview paragraph shown in the detail page header
  overview        String    @db.Text
  /// "My Contribution" section — describes Rohit's specific role & work
  contribution    String    @db.Text
  /// Full MDX body for the detail page (architecture, stack deep-dive, lessons)
  body            String    @db.Text
  featured        Boolean   @default(false)
  order           Int       @default(0)
  published       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([featured, order])
  @@index([published, order])
}

// ─────────────────────────────────────────────────────────────
//  BLOG POST
// ─────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  coverImage  String?
  tags        String[]
  /// Full MDX body (authored in admin, rendered on public with syntax highlighting)
  body        String    @db.Text
  readingTime Int?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published, publishedAt])
}

// ─────────────────────────────────────────────────────────────
//  SKILL
// ─────────────────────────────────────────────────────────────

model Skill {
  id    String     @id @default(cuid())
  group String
  name  String
  level SkillLevel
  order Int        @default(0)

  @@index([group, order])
  @@index([level])
}

// ─────────────────────────────────────────────────────────────
//  EXPERIENCE
// ─────────────────────────────────────────────────────────────

model Experience {
  id        String    @id @default(cuid())
  role      String
  company   String
  location  String
  startDate DateTime
  /// null = "Present" (current role)
  endDate   DateTime?
  /// Optional company logo — Cloudinary URL
  logo      String?
  bullets   String[]
  order     Int       @default(0)

  @@index([order])
}

// ─────────────────────────────────────────────────────────────
//  EDUCATION  (degrees, institutions)
//  NOTE: adding this model requires a migration —
//  run `npx prisma migrate dev --name add_education`.
// ─────────────────────────────────────────────────────────────

model Education {
  id        String    @id @default(cuid())
  degree    String
  school    String
  startDate DateTime
  /// null = ongoing / "Present" (currently studying)
  endDate   DateTime?
  detail    String?
  /// Optional institution logo — Cloudinary URL
  logo      String?
  order     Int       @default(0)

  @@index([order])
}

// ─────────────────────────────────────────────────────────────
//  ACHIEVEMENT  (awards, education, mentoring)
// ─────────────────────────────────────────────────────────────

model Achievement {
  id          String    @id @default(cuid())
  title       String
  description String
  /// Date the achievement was earned (null = unspecified)
  date        DateTime?
  /// Optional photo (e.g. award certificate) — Cloudinary URL
  image       String?
  order       Int       @default(0)

  @@index([order])
}

// ─────────────────────────────────────────────────────────────
//  SITE SETTINGS  —  singleton row (id = "singleton")
// ─────────────────────────────────────────────────────────────

model SiteSettings {
  /// Always "singleton" — enforced by the upsert pattern in the API.
  id            String       @id @default("singleton")
  name          String
  tagline       String
  email         String
  location      String
  /// JSON: { github: string, linkedin: string, twitter?: string }
  socials       Json
  resumeUrl     String?
  defaultTheme  DefaultTheme @default(DARK)
  brandAccent   String?
  footerText    String?
  ogTitle       String?
  ogDescription String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─────────────────────────────────────────────────────────────
//  MEDIA  —  Cloudinary-backed asset record
// ─────────────────────────────────────────────────────────────

model Media {
  id           String   @id @default(cuid())
  cloudinaryUrl String
  publicId     String   @unique
  alt          String?
  width        Int?
  height       Int?
  /// e.g. "image/jpeg", "image/png", "image/webp"
  type         String?
  /// Library grouping, e.g. "Projects", "Blog", "Awards", "Profile", "Misc"
  category     String   @default("Misc")
  createdAt    DateTime @default(now())

  @@index([publicId])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
//  ADMIN USER  —  single admin (Rohit); seeded from env
// ─────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────
//  CONFIGURATION  — admin-editable option lists for dropdowns
//  (e.g. contact link types, social link types, skill groups).
//  NOTE: schema enums (SectionType, SkillLevel, …) stay
//  code-defined and are served read-only via GET /api/config/enums.
//  SkillGroup was intentionally removed as a Prisma enum — group
//  ordering and labels now live in the `skill_groups` config row.
// ─────────────────────────────────────────────────────────────

model Configuration {
  id        String   @id @default(cuid())
  /// Stable key, e.g. "contact_link_types"
  key       String   @unique
  label     String
  /// JSON array of { value: string, label: string }
  items     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

// ─────────────────────────────────────────────────────────────
//  CONTACT  —  visitor messages + Gmail two-way sync
// ─────────────────────────────────────────────────────────────

model ContactThread {
  id            String   @id @default(cuid())
  /// Visitor display name
  name          String
  /// Visitor email address
  email         String
  subject       String?
  /// Gmail thread ID, set when the notification email is sent via Gmail API
  gmailThreadId String?  @unique
  /// Whether the admin has read this thread
  unread        Boolean  @default(true)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  messages ContactMessage[]

  @@index([lastMessageAt])
}

model ContactMessage {
  id             String   @id @default(cuid())
  threadId       String
  /// 'inbound' (from visitor) | 'outbound' (from admin)
  direction      String
  /// 'web' | 'app' | 'gmail' | 'notification'
  source         String
  body           String   @db.Text
  /// Gmail message ID — used for deduplication during sync
  gmailMessageId String?  @unique
  createdAt      DateTime @default(now())

  thread ContactThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
