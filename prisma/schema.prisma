// =============================================================
//  portfolio-backend — Prisma Schema
//  DB: PostgreSQL  |  ORM: Prisma 5  |  IDs: cuid()
//
//  Structure source-of-truth: step4.md §3
//  Content seed source-of-truth: step3.md
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────

enum SectionType {
  HERO
  ABOUT
  SKILLS
  EXPERIENCE
  FEATURED_PROJECTS
  PROJECTS_GRID
  BLOG_TEASER
  ACHIEVEMENTS
  EDUCATION
  CONTACT
  METRICS
  RICH_TEXT
  CTA
  GALLERY
}

enum SkillLevel {
  EXPERT
  PROFICIENT
  FAMILIAR
}

enum DefaultTheme {
  DARK
  LIGHT
}

// ─────────────────────────────────────────────────────────────
//  ADMIN USER  —  single admin (Rohit); seeded from env
//  No createdBy/updatedBy on AdminUser itself — it is the
//  audit principal, seeded from env, not subject to the trail.
// ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // ── Audit back-relations — one created/updated pair per audited model ──────

  createdProjects        Project[]        @relation("ProjectCreatedBy")
  updatedProjects        Project[]        @relation("ProjectUpdatedBy")

  createdBlogPosts       BlogPost[]       @relation("BlogPostCreatedBy")
  updatedBlogPosts       BlogPost[]       @relation("BlogPostUpdatedBy")

  createdExperiences     Experience[]     @relation("ExperienceCreatedBy")
  updatedExperiences     Experience[]     @relation("ExperienceUpdatedBy")

  createdEducations      Education[]      @relation("EducationCreatedBy")
  updatedEducations      Education[]      @relation("EducationUpdatedBy")

  createdAchievements    Achievement[]    @relation("AchievementCreatedBy")
  updatedAchievements    Achievement[]    @relation("AchievementUpdatedBy")

  createdSkills          Skill[]          @relation("SkillCreatedBy")
  updatedSkills          Skill[]          @relation("SkillUpdatedBy")

  createdPages           Page[]           @relation("PageCreatedBy")
  updatedPages           Page[]           @relation("PageUpdatedBy")

  createdMedia           Media[]          @relation("MediaCreatedBy")
  updatedMedia           Media[]          @relation("MediaUpdatedBy")

  createdSiteSettings    SiteSettings[]   @relation("SiteSettingsCreatedBy")
  updatedSiteSettings    SiteSettings[]   @relation("SiteSettingsUpdatedBy")

  createdConfigurations  Configuration[]  @relation("ConfigurationCreatedBy")
  updatedConfigurations  Configuration[]  @relation("ConfigurationUpdatedBy")

  createdSections        Section[]        @relation("SectionCreatedBy")
  updatedSections        Section[]        @relation("SectionUpdatedBy")

  createdContactThreads  ContactThread[]  @relation("ContactThreadCreatedBy")
  updatedContactThreads  ContactThread[]  @relation("ContactThreadUpdatedBy")

  createdContactMessages ContactMessage[] @relation("ContactMessageCreatedBy")
  updatedContactMessages ContactMessage[] @relation("ContactMessageUpdatedBy")

  @@index([email])
}

// ─────────────────────────────────────────────────────────────
//  MEDIA  —  Cloudinary-backed asset record
//
//  Polymorphic owner reference: ownerType + ownerId replace
//  the previous 7 typed FK columns.  Linking happens at upload
//  time (deferred-upload flow): the frontend POSTs the file with
//  ownerId + ownerType already set so the row is linked immediately.
//
//  ownerType values: 'project' | 'blog' | 'experience' |
//                    'education' | 'achievement' | 'page' | 'settings'
//
//  `usage` discriminates multi-purpose owners, e.g. on settings:
//    usage='resume'  → resume file
//    usage='og'      → OG image
// ─────────────────────────────────────────────────────────────

model Media {
  id            String   @id @default(cuid())
  cloudinaryUrl String
  publicId      String   @unique
  alt           String?
  width         Int?
  height        Int?
  /// e.g. "image/jpeg", "image/png", "image/webp"
  type          String?
  /// Library grouping, e.g. "Projects", "Blog", "Raw"
  category      String   @default("Misc")
  createdAt     DateTime @default(now())
  /// Display order within the owning collection (0-based)
  order         Int      @default(0)
  /// Discriminator for multi-purpose owners, e.g. "resume" | "og" on SiteSettings
  usage         String?

  // Polymorphic owner reference
  ownerId   String?
  ownerType String?

  // Audit trail — uploader IS the creator
  createdById String?
  createdBy   AdminUser? @relation("MediaCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("MediaUpdatedBy", fields: [updatedById], references: [id])

  @@index([ownerType, ownerId, order])
  @@index([publicId])
  @@index([category])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  PAGE  —  a URL-addressable page composed of ordered Sections
// ─────────────────────────────────────────────────────────────

model Page {
  id              String    @id @default(cuid())
  slug            String    @unique
  /// Title must also be unique across pages.
  title           String    @unique
  metaTitle       String?
  metaDescription String?
  navLabel        String?
  navOrder        Int       @default(0)
  showInNav       Boolean   @default(false)
  published       Boolean   @default(true)
  /// isSystem = true means this page is required by the app (cannot be deleted from admin)
  isSystem        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Audit trail (replaces the old required authorId)
  createdById String?
  createdBy   AdminUser? @relation("PageCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("PageUpdatedBy", fields: [updatedById], references: [id])

  sections Section[]

  @@index([slug])
  @@index([showInNav, navOrder])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  SECTION  —  a predefined-type content block on a Page
//  data(Json) holds the per-type shape (see step4 §3.2)
// ─────────────────────────────────────────────────────────────

model Section {
  id        String      @id @default(cuid())
  pageId    String
  type      SectionType
  /// 0-based display order within the page
  order     Int         @default(0)
  enabled   Boolean     @default(true)
  /// Flexible JSON payload — shape is determined by `type` (see step4 §3.2).
  data      Json        @default("{}")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  // Audit trail
  createdById String?
  createdBy   AdminUser? @relation("SectionCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("SectionUpdatedBy", fields: [updatedById], references: [id])

  @@index([pageId, order])
  @@index([pageId, enabled])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  PROJECT
// ─────────────────────────────────────────────────────────────

model Project {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  oneLiner     String
  role         String
  tags         String[]
  stack        String[]
  /// Headline metric string displayed on the card
  metric       String
  liveUrl      String?
  /// Short overview paragraph shown in the detail page header
  overview     String   @db.Text
  /// "My Contribution" section
  contribution String   @db.Text
  /// Full MDX body for the detail page
  body         String   @db.Text
  featured     Boolean  @default(false)
  order        Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Audit trail (replaces the old required authorId)
  createdById String?
  createdBy   AdminUser? @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("ProjectUpdatedBy", fields: [updatedById], references: [id])

  @@index([slug])
  @@index([featured, order])
  @@index([published, order])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  BLOG POST
// ─────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  tags        String[]
  /// Full MDX body
  body        String    @db.Text
  readingTime Int?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Audit trail (replaces the old required authorId)
  createdById String?
  createdBy   AdminUser? @relation("BlogPostCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("BlogPostUpdatedBy", fields: [updatedById], references: [id])

  @@index([slug])
  @@index([published, publishedAt])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  SKILL
// ─────────────────────────────────────────────────────────────

model Skill {
  id    String     @id @default(cuid())
  group String
  name  String
  level SkillLevel
  order Int        @default(0)

  // Audit trail (replaces the old required authorId)
  createdById String?
  createdBy   AdminUser? @relation("SkillCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("SkillUpdatedBy", fields: [updatedById], references: [id])

  @@index([group, order])
  @@index([level])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  EXPERIENCE
// ─────────────────────────────────────────────────────────────

model Experience {
  id        String    @id @default(cuid())
  role      String
  company   String
  location  String
  startDate DateTime
  /// null = "Present" (current role)
  endDate   DateTime?
  bullets   String[]
  order     Int       @default(0)

  // Audit trail (replaces the old required authorId)
  createdById String?
  createdBy   AdminUser? @relation("ExperienceCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("ExperienceUpdatedBy", fields: [updatedById], references: [id])

  @@index([order])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  EDUCATION
// ─────────────────────────────────────────────────────────────

model Education {
  id        String    @id @default(cuid())
  degree    String
  school    String
  startDate DateTime
  /// null = ongoing / "Present"
  endDate   DateTime?
  detail    String?
  order     Int       @default(0)

  // Audit trail (replaces the old required authorId)
  createdById String?
  createdBy   AdminUser? @relation("EducationCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("EducationUpdatedBy", fields: [updatedById], references: [id])

  @@index([order])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  ACHIEVEMENT  (awards, education, mentoring)
// ─────────────────────────────────────────────────────────────

model Achievement {
  id          String    @id @default(cuid())
  title       String
  description String
  /// Date the achievement was earned (null = unspecified)
  date        DateTime?
  order       Int       @default(0)

  // Audit trail (replaces the old required authorId)
  createdById String?
  createdBy   AdminUser? @relation("AchievementCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("AchievementUpdatedBy", fields: [updatedById], references: [id])

  @@index([order])
  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  SITE SETTINGS  —  singleton row (id = "singleton")
// ─────────────────────────────────────────────────────────────

model SiteSettings {
  /// Always "singleton" — enforced by the upsert pattern in the API.
  id            String       @id @default("singleton")
  name          String
  tagline       String
  email         String
  location      String
  /// JSON: { github: string, linkedin: string, twitter?: string }
  socials       Json
  defaultTheme  DefaultTheme @default(DARK)
  brandAccent   String?
  footerText    String?
  ogTitle       String?
  ogDescription String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Audit trail
  createdById String?
  createdBy   AdminUser? @relation("SiteSettingsCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("SiteSettingsUpdatedBy", fields: [updatedById], references: [id])
}

// ─────────────────────────────────────────────────────────────
//  CONFIGURATION  — admin-editable option lists for dropdowns
// ─────────────────────────────────────────────────────────────

model Configuration {
  id        String   @id @default(cuid())
  /// Stable key, e.g. "contact_link_types"
  key       String   @unique
  label     String
  /// JSON array of { value: string, label: string }
  items     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Audit trail
  createdById String?
  createdBy   AdminUser? @relation("ConfigurationCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("ConfigurationUpdatedBy", fields: [updatedById], references: [id])

  @@index([createdById])
}

// ─────────────────────────────────────────────────────────────
//  CONTACT  —  visitor messages + Gmail two-way sync
// ─────────────────────────────────────────────────────────────

model ContactThread {
  id            String   @id @default(cuid())
  /// Visitor display name
  name          String
  /// Visitor email address
  email         String
  subject       String?
  /// Gmail thread ID, set when the notification email is sent via Gmail API
  gmailThreadId String?  @unique
  /// Whether the admin has read this thread
  unread        Boolean  @default(true)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  // Audit trail — createdById stays NULL for web/Gmail-sync created threads;
  // updatedById is set to the admin id on reply/compose/markRead/markAllRead.
  createdById String?
  createdBy   AdminUser? @relation("ContactThreadCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("ContactThreadUpdatedBy", fields: [updatedById], references: [id])

  messages ContactMessage[]

  @@index([lastMessageAt])
  @@index([updatedById])
}

model ContactMessage {
  id             String   @id @default(cuid())
  threadId       String
  /// 'inbound' (from visitor) | 'outbound' (from admin)
  direction      String
  /// 'web' | 'app' | 'gmail' | 'notification'
  source         String
  body           String   @db.Text
  /// Gmail message ID — used for deduplication during sync
  gmailMessageId String?  @unique
  createdAt      DateTime @default(now())

  thread ContactThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  // Audit trail — createdById set to admin id for outbound app messages;
  // NULL for inbound visitor messages and Gmail-synced messages.
  // updatedById stays NULL (messages are immutable after creation).
  createdById String?
  createdBy   AdminUser? @relation("ContactMessageCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   AdminUser? @relation("ContactMessageUpdatedBy", fields: [updatedById], references: [id])

  @@index([threadId, createdAt])
  @@index([createdById])
}
